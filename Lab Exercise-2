#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
int main()
{
    int s, d, n;
    char b[100];
    s = open("source.txt", O_RDONLY);
    d = open("dest.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
    while ((n = read(s, b, 100)) > 0)
        write(d, b, n);
    close(s);
    close(d);
    printf("File copied successfully.\n");
    return 0;
}
