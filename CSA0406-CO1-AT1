ANSWER-3 :
a)open: Opens the source and destination files.
read: Retrieves data from the source file.
write: Writes data to the destination file.
close: Closes both files after the operation.
b)read: This system call copies a specified number of bytes from an open file descriptor into a buffer in the program's memory.
        It advances the file offset pointer by the number of bytes read.
  write: This system call takes data from a buffer in the program'smemory and writes it to an open file descriptor.
         It creates or overwrites data at the current file offset pointer.
c)#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <stdlib.h>
#define BUFFER_SIZE 1024
int main(int argc, char *argv[]) {
    int src_fd, dest_fd;
    ssize_t bytes_read, bytes_written;
    char buffer[BUFFER_SIZE];
    if (argc != 3) {
        write(STDERR_FILENO, "Usage: copy <source> <destination>\n", 35);
        exit(1);
    }
    src_fd = open(argv[1], O_RDONLY);
    if (src_fd < 0) {
        perror("Error opening source file");
        exit(1);
    }
    dest_fd = open(argv[2], O_WRONLY | O_CREAT | O_TRUNC, 0644);
    if (dest_fd < 0) {
        perror("Error opening/creating destination file");
        close(src_fd);
        exit(1);
    }
    while ((bytes_read = read(src_fd, buffer, BUFFER_SIZE)) > 0) {
        bytes_written = write(dest_fd, buffer, bytes_read);
        if (bytes_written != bytes_read) {
            perror("Error writing to destination file");
            close(src_fd);
            close(dest_fd);
            exit(1);
        }
    }
    if (bytes_read < 0) {
        perror("Error reading source file");
    }
    close(src_fd);
    close(dest_fd);
    return 0;
}
