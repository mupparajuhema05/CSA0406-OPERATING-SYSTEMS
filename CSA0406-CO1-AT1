int main() {
    pid_t pid;
    pid = fork();
    if (pid < 0) {
        perror("Fork failed");
        exit(1);
    } 
    else if (pid == 0) {
        printf("Child Process: Executing 'ls' command...\n");
        execlp("ls", "ls", "-l", NULL);
        perror("Exec failed");
        exit(1);
    } 
    else {
        printf("Parent Process: Waiting for child to finish...\n");
        wait(NULL); 
        printf("Parent Process: Child has finished execution.\n");
    }
    return 0;
}
