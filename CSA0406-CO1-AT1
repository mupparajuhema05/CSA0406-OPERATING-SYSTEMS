b)open(): Establishes a connection between a process and a file. It searches the disk for the file, loads its control block into
          the system-wide open-file table, verifies permissions, and returns a file descriptor for subsequent operations.
close(): Breaks the connection between the process and the file. It deallocates the file descriptor flushes any remaining 
         buffered data to the storage device, and updates the file's metadata in the directory structure.
c)#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>
#define BUFFER_SIZE 1024
int main() {
    int fd;
    ssize_t bytes_read;
    char buffer[BUFFER_SIZE];
    fd = open("example.txt", O_RDONLY);
    if (fd == -1) {
        perror("Error opening file");
        exit(EXIT_FAILURE);
    }
    while ((bytes_read = read(fd, buffer, BUFFER_SIZE)) > 0) {
        write(STDOUT_FILENO, buffer, bytes_read);
    }
    if (bytes_read == -1) {
        perror("Error reading file");
        close(fd);
        exit(EXIT_FAILURE);
    }
    if (close(fd) == -1) {
        perror("Error closing file");
        exit(EXIT_FAILURE);
    }
    return EXIT_SUCCESS;
}





